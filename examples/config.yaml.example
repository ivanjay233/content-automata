# content-automata configuration
# Copy this to config.yaml and fill in your API keys.

api_key: "your-api-key-here"  # Default API key used by all stages

research:
  provider: "tavily"          # Options: tavily, exa
  api_key: "your-research-api-key"  # Optional, falls back to api_key above
  max_results: 5              # Number of search results to fetch

copywriting:
  default_tone: "professional"  # Options: professional, casual, persuasive, humorous, authoritative
  variants:                     # Content variants to generate
    - blog
    - social
    - ad

image_generation:
  provider: "openai"          # Options: openai, stability
  api_key: "your-image-api-key"   # Optional, falls back to api_key above
  default_aspect: "16:9"      # Options: 1:1, 4:3, 16:9, 9:16, 3:2, 2:3

scheduling:
  export_formats:             # Export formats to generate
    - markdown
    - html
    - csv
  output_dir: "./output"      # Directory for exported files
